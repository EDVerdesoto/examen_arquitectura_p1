<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CLIESC.Vistas.ResumenPage"
             Title="Resumen">

    <Shell.TitleView>
        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
            <Label Text="TicketPremium"
                   TextColor="{StaticResource White}"
                   FontFamily="OpenSansSemibold"
                   FontSize="16"
                   VerticalOptions="Center" />
            <Label Grid.Column="1"
                   Text="Resumen de ventas"
                   TextColor="#CCFFFFFF"
                   FontSize="13"
                   VerticalOptions="Center" />
        </Grid>
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="0,8,0,20"
                             MaximumWidthRequest="1200"
                             HorizontalOptions="Center">

            <!-- Header Card -->
            <Frame Style="{StaticResource HeaderCard}">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Resumen de ventas por partido"
                               Style="{StaticResource PageTitle}" />
                        <Label Text="Consulta el desempeno de ventas de cada encuentro"
                               TextColor="#CCFFFFFF"
                               FontSize="13" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1"
                            Text="Volver a partidos"
                            Style="{StaticResource OutlineButton}"
                            TextColor="{StaticResource White}"
                            BorderColor="{StaticResource White}"
                            Clicked="OnVolverPartidosClicked"
                            VerticalOptions="Center" />
                </Grid>
            </Frame>

            <!-- Loading -->
            <VerticalStackLayout x:Name="LoadingStack"
                                 IsVisible="True"
                                 HorizontalOptions="Center"
                                 Padding="0,60,0,0"
                                 Spacing="8">
                <ActivityIndicator IsRunning="True"
                                   WidthRequest="48"
                                   HeightRequest="48"
                                   Color="{StaticResource Primary}" />
                <Label Text="Cargando informacion..."
                       Style="{StaticResource MutedLabel}"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Error -->
            <Frame x:Name="ErrorFrame"
                   IsVisible="False"
                   Margin="0,8"
                   BackgroundColor="#FFE5E5"
                   BorderColor="{StaticResource Danger}"
                   CornerRadius="8"
                   Padding="12,10"
                   HasShadow="False">
                <Label x:Name="ErrorLabel"
                       TextColor="{StaticResource Danger}"
                       FontSize="13" />
            </Frame>

            <!-- Empty -->
            <Frame x:Name="EmptyFrame"
                   IsVisible="False"
                   Margin="0,8"
                   BackgroundColor="#E8F4FD"
                   BorderColor="{StaticResource Accent}"
                   CornerRadius="8"
                   Padding="16"
                   HasShadow="False">
                <Label Text="No hay informacion de ventas disponible."
                       TextColor="{StaticResource Primary}"
                       FontSize="14"
                       HorizontalTextAlignment="Center" />
            </Frame>

            <!-- Resumen Grid -->
            <FlexLayout x:Name="ResumenGrid"
                        IsVisible="False"
                        Wrap="Wrap"
                        JustifyContent="Center"
                        Direction="Row"
                        AlignItems="Stretch" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
