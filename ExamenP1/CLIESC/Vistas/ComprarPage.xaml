<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CLIESC.Vistas.ComprarPage"
             Title="Comprar">

    <Shell.TitleView>
        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
            <Label Text="TicketPremium"
                   TextColor="{StaticResource White}"
                   FontFamily="OpenSansSemibold"
                   FontSize="16"
                   VerticalOptions="Center" />
            <Label Grid.Column="1"
                   Text="Comprar boletos"
                   TextColor="#CCFFFFFF"
                   FontSize="13"
                   VerticalOptions="Center" />
        </Grid>
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="0,8,0,20"
                             MaximumWidthRequest="1200"
                             HorizontalOptions="Center">

            <!-- Header Card -->
            <Frame x:Name="HeaderCard"
                   Style="{StaticResource HeaderCard}">
                <VerticalStackLayout Spacing="4">
                    <Label x:Name="HeaderTitle"
                           Text="Comprar boletos"
                           Style="{StaticResource PageTitle}" />
                    <Label x:Name="HeaderSubtitle"
                           TextColor="#CCFFFFFF"
                           FontSize="12" />
                </VerticalStackLayout>
            </Frame>

            <!-- Loading -->
            <VerticalStackLayout x:Name="LoadingStack"
                                 IsVisible="True"
                                 HorizontalOptions="Center"
                                 Padding="0,60,0,0"
                                 Spacing="8">
                <ActivityIndicator IsRunning="True"
                                   WidthRequest="48"
                                   HeightRequest="48"
                                   Color="{StaticResource Primary}" />
                <Label Text="Cargando informacion..."
                       Style="{StaticResource MutedLabel}"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Error -->
            <Frame x:Name="ErrorFrame"
                   IsVisible="False"
                   Margin="0,8"
                   BackgroundColor="#FFE5E5"
                   BorderColor="{StaticResource Danger}"
                   CornerRadius="8"
                   Padding="12,10"
                   HasShadow="False">
                <Label x:Name="ErrorLabel"
                       TextColor="{StaticResource Danger}"
                       FontSize="13" />
            </Frame>

            <!-- Main Content Grid (Form + Image) -->
            <Grid x:Name="ContentGrid"
                  IsVisible="False"
                  ColumnDefinitions="3*,2*"
                  ColumnSpacing="16">

                <!-- Left Column: Form or Success -->
                <VerticalStackLayout Grid.Column="0">

                    <!-- Purchase Form -->
                    <Frame x:Name="CompraFormCard"
                           IsVisible="False"
                           Style="{StaticResource MatchCard}"
                           Padding="20">
                        <VerticalStackLayout Spacing="16">

                            <Button x:Name="BackButton"
                                    Text="Volver a localidades"
                                    BackgroundColor="Transparent"
                                    TextColor="{StaticResource Primary}"
                                    HorizontalOptions="Start"
                                    Padding="0"
                                    FontSize="13"
                                    Clicked="OnBackToLocalidadesClicked" />

                            <Frame BackgroundColor="{StaticResource CardBackground}"
                                   CornerRadius="8"
                                   Padding="14"
                                   HasShadow="False">
                                <VerticalStackLayout Spacing="6">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Label Text="Localidad:" Style="{StaticResource MutedLabel}" />
                                        <Label x:Name="LocalidadNameLabel"
                                               Style="{StaticResource BoldLabel}"
                                               Grid.Column="1"
                                               HorizontalTextAlignment="End" />
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Label Text="Precio unitario:" Style="{StaticResource MutedLabel}" />
                                        <Label x:Name="PrecioUnitarioLabel"
                                               Style="{StaticResource BoldLabel}"
                                               Grid.Column="1"
                                               HorizontalTextAlignment="End" />
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Label Text="Disponibles:" Style="{StaticResource MutedLabel}" />
                                        <Label x:Name="DisponiblesLabel"
                                               Style="{StaticResource BoldLabel}"
                                               Grid.Column="1"
                                               HorizontalTextAlignment="End" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Frame>

                            <VerticalStackLayout Spacing="4">
                                <Label Text="Cantidad de boletos"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="14"
                                       TextColor="{StaticResource TextDark}" />
                                <Entry x:Name="CantidadEntry"
                                       Placeholder="1"
                                       Keyboard="Numeric"
                                       ReturnType="Done"
                                       Text="1"
                                       TextChanged="OnCantidadChanged" />
                                <Label x:Name="MaxLabel"
                                       Style="{StaticResource MutedLabel}"
                                       FontSize="11" />
                            </VerticalStackLayout>

                            <Frame x:Name="PrecioDesglose"
                                   IsVisible="False"
                                   BackgroundColor="{StaticResource CardBackground}"
                                   CornerRadius="8"
                                   Padding="14"
                                   HasShadow="False">
                                <VerticalStackLayout Spacing="6">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="Subtotal" Style="{StaticResource MutedLabel}" />
                                        <Label x:Name="SubtotalLabel" Style="{StaticResource BoldLabel}" Grid.Column="1" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="IVA (15%)" Style="{StaticResource MutedLabel}" />
                                        <Label x:Name="IvaLabel" Style="{StaticResource BoldLabel}" Grid.Column="1" />
                                    </Grid>
                                    <BoxView HeightRequest="1" Color="{StaticResource Gray200}" />
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="Total" FontFamily="OpenSansSemibold" FontSize="15" TextColor="{StaticResource TextDark}" />
                                        <Label x:Name="TotalLabel" TextColor="{StaticResource Success}" FontFamily="OpenSansSemibold" FontSize="16" Grid.Column="1" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Frame>

                            <Button x:Name="ConfirmButton"
                                    Text="Confirmar compra"
                                    Style="{StaticResource PrimaryButton}"
                                    Clicked="OnComprarClicked" />

                        </VerticalStackLayout>
                    </Frame>

                    <!-- Success -->
                    <Frame x:Name="SuccessCard"
                           IsVisible="False"
                           Style="{StaticResource MatchCard}"
                           BorderColor="{StaticResource Success}"
                           Padding="20">
                        <VerticalStackLayout Spacing="16">
                            <VerticalStackLayout HorizontalOptions="Center" Spacing="8">
                                <Label Text="Compra exitosa"
                                       FontSize="22"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource Success}"
                                       HorizontalTextAlignment="Center" />
                                <Label x:Name="SuccessMessage"
                                       Style="{StaticResource MutedLabel}"
                                       HorizontalTextAlignment="Center"
                                       FontSize="14" />
                            </VerticalStackLayout>

                            <Frame BackgroundColor="{StaticResource CardBackground}"
                                   CornerRadius="8" Padding="14" HasShadow="False">
                                <VerticalStackLayout Spacing="6">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Label Text="Factura #:" Style="{StaticResource MutedLabel}" />
                                        <Label x:Name="FacturaIdLabel" Style="{StaticResource BoldLabel}" Grid.Column="1" HorizontalTextAlignment="End" />
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Label Text="Localidad:" Style="{StaticResource MutedLabel}" />
                                        <Label x:Name="FacturaLocalidadLabel" Style="{StaticResource BoldLabel}" Grid.Column="1" HorizontalTextAlignment="End" />
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Label Text="Cantidad:" Style="{StaticResource MutedLabel}" />
                                        <Label x:Name="FacturaCantidadLabel" Style="{StaticResource BoldLabel}" Grid.Column="1" HorizontalTextAlignment="End" />
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Label Text="Precio unitario:" Style="{StaticResource MutedLabel}" />
                                        <Label x:Name="FacturaPrecioLabel" Style="{StaticResource BoldLabel}" Grid.Column="1" HorizontalTextAlignment="End" />
                                    </Grid>
                                    <BoxView HeightRequest="1" Color="{StaticResource Gray200}" />
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Label Text="Subtotal:" Style="{StaticResource MutedLabel}" />
                                        <Label x:Name="FacturaSubtotalLabel" Style="{StaticResource BoldLabel}" Grid.Column="1" HorizontalTextAlignment="End" />
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Label Text="IVA (15%):" Style="{StaticResource MutedLabel}" />
                                        <Label x:Name="FacturaIvaLabel" Style="{StaticResource BoldLabel}" Grid.Column="1" HorizontalTextAlignment="End" />
                                    </Grid>
                                    <BoxView HeightRequest="1" Color="{StaticResource Gray200}" />
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Label Text="Total:" FontFamily="OpenSansSemibold" FontSize="15" TextColor="{StaticResource TextDark}" />
                                        <Label x:Name="FacturaTotalLabel" TextColor="{StaticResource Success}" FontFamily="OpenSansSemibold" FontSize="18" Grid.Column="1" HorizontalTextAlignment="End" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Frame>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                <Button Text="Ver mas partidos" Style="{StaticResource PrimaryButton}" Clicked="OnVerMasPartidosClicked" />
                                <Button Grid.Column="1" Text="Nueva compra" Style="{StaticResource OutlineButton}" Clicked="OnNuevaCompraClicked" />
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>

                </VerticalStackLayout>

                <!-- Right Column: Stadium Image -->
                <Frame Grid.Column="1"
                       CornerRadius="12"
                       Padding="0"
                       HasShadow="True"
                       BorderColor="Transparent"
                       IsClippedToBounds="True">
                    <Image Source="estadio.jpg"
                           Aspect="AspectFill" />
                </Frame>

            </Grid>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
