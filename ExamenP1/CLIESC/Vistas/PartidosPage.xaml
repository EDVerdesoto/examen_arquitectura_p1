<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CLIESC.Vistas.PartidosPage"
             Title="TicketPremium"
             BackgroundImageSource="fondo.jpg">

    <Shell.TitleView>
        <Grid ColumnDefinitions="*,Auto" Padding="0,0,8,0">
            <Label Text="TicketPremium"
                   TextColor="{StaticResource White}"
                   FontFamily="OpenSansSemibold"
                   FontSize="18"
                   VerticalOptions="Center" />
            <Button Grid.Column="1"
                    Text="Cerrar sesion"
                    Style="{StaticResource OutlineButton}"
                    TextColor="{StaticResource White}"
                    BorderColor="{StaticResource White}"
                    FontSize="12"
                    Padding="12,6"
                    Clicked="OnLogoutClicked"
                    VerticalOptions="Center" />
        </Grid>
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="0,8,0,20"
                             MaximumWidthRequest="1500"
                             HorizontalOptions="Center">

            <!-- Header Card -->
            <Frame Style="{StaticResource HeaderCard}">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                    <Border StrokeShape="RoundRectangle 12"
                            Stroke="rgba(255,255,255,0.3)"
                            StrokeThickness="2"
                            BackgroundColor="White"
                            WidthRequest="96" HeightRequest="96"
                            VerticalOptions="Center">
                        <Image Source="monsterpartidos.png"
                               Aspect="AspectFit" />
                    </Border>
                    <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                        <Label Text="Partidos disponibles"
                               Style="{StaticResource PageTitle}" />
                        <Label Text="Encuentra los mejores partidos y compra tus boletos"
                               TextColor="#CCFFFFFF"
                               FontSize="13" />
                    </VerticalStackLayout>
                    <Button Grid.Column="2"
                            Text="Resumen de ventas"
                            Style="{StaticResource OutlineButton}"
                            TextColor="{StaticResource White}"
                            BorderColor="{StaticResource White}"
                            Clicked="OnResumenClicked"
                            VerticalOptions="Center" />
                </Grid>
            </Frame>

            <!-- Loading -->
            <VerticalStackLayout x:Name="LoadingStack"
                                 IsVisible="True"
                                 HorizontalOptions="Center"
                                 Padding="0,60,0,0"
                                 Spacing="8">
                <ActivityIndicator IsRunning="True"
                                   WidthRequest="48"
                                   HeightRequest="48"
                                   Color="{StaticResource Primary}" />
                <Label Text="Cargando partidos..."
                       Style="{StaticResource MutedLabel}"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Error -->
            <Frame x:Name="ErrorFrame"
                   IsVisible="False"
                   Margin="0,8"
                   BackgroundColor="#FFE5E5"
                   BorderColor="{StaticResource Danger}"
                   CornerRadius="8"
                   Padding="12,10"
                   HasShadow="False">
                <Label x:Name="ErrorLabel"
                       TextColor="{StaticResource Danger}"
                       FontSize="13" />
            </Frame>

            <!-- Empty -->
            <Frame x:Name="EmptyFrame"
                   IsVisible="False"
                   Margin="0,8"
                   BackgroundColor="#E8F4FD"
                   BorderColor="{StaticResource Accent}"
                   CornerRadius="8"
                   Padding="16"
                   HasShadow="False">
                <Label Text="No hay partidos disponibles en este momento."
                       TextColor="{StaticResource Primary}"
                       FontSize="14"
                       HorizontalTextAlignment="Center" />
            </Frame>

            <!-- Partidos Grid -->
            <FlexLayout x:Name="PartidosGrid"
                        IsVisible="False"
                        Wrap="Wrap"
                        JustifyContent="Center"
                        Direction="Row"
                        AlignItems="Stretch" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
