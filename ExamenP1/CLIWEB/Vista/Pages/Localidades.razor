@page "/partido/{CodigoPartido:int}/localidades"
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Localidades - TicketPremium</PageTitle>

@if (partido != null)
{
    <div class="card page-header-card mb-5">
        <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
            <div class="d-flex align-items-center gap-3">
                <img src="images/monster-partidos.png" class="header-card-img" alt="" />
                <div class="text-center text-md-start">
                    <h1 class="fs-2 mb-1">
                        <i class="bi bi-ticket-perforated-fill"></i> Localidades disponibles
                    </h1>
                    <p class="mb-0 opacity-75">
                    <i class="bi bi-trophy-fill"></i> @partido.EquipoLocal vs @partido.EquipoVisita
                    <span class="mx-1">—</span>
                    <i class="bi bi-calendar3"></i> @partido.Fecha.ToString("dd/MM/yyyy HH:mm")
                    <span class="mx-1">—</span>
                    <i class="bi bi-geo-alt-fill"></i> @partido.Lugar
                </p>
                </div>
            </div>
            <a href="/resumen-ventas/@CodigoPartido" class="btn btn-outline-light">
                <i class="bi bi-bar-chart-fill"></i> Ver resumen de ventas
            </a>
        </div>
    </div>
}

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
        <p class="mt-2 text-muted">Cargando localidades...</p>
    </div>
}
else if (errorMessage != null)
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (localidades.Length == 0)
{
    <div class="alert alert-info">No hay localidades disponibles para este partido.</div>
}
else
{
    <div class="localidades-grid">
        @foreach (var loc in localidades)
        {
            <div class="card h-100 shadow-sm localidad-card @(loc.Disponibilidad == 0 ? "border-danger opacity-75" : "")">
                <div class="card-body d-flex flex-column">
                    <h4 class="team-name mb-2">@loc.CodigoLocalidad</h4>

                    <div class="mb-3">
                        <span class="localidad-badge @(loc.Disponibilidad > 0 ? "disponible" : "agotado")">
                            @(loc.Disponibilidad > 0 ? $"{loc.Disponibilidad} disponibles" : "Agotado")
                        </span>
                    </div>

                    <div class="mb-3">
                        <h3 class="localidad-precio mb-0">$@loc.Precio.ToString("N2")</h3>
                        <small class="text-muted">por boleto</small>
                    </div>

                    @if (loc.Disponibilidad > 0)
                    {
                        <a href="/comprar/@CodigoPartido/@Uri.EscapeDataString(loc.CodigoLocalidad)"
                           class="btn-match-action mt-auto">
                            <i class="bi bi-cart3"></i> Comprar
                        </a>
                    }
                    else
                    {
                        <button class="btn btn-secondary w-100 mt-auto" disabled>
                            <i class="bi bi-x-circle"></i> Agotado
                        </button>
                    }
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter] public int CodigoPartido { get; set; }

    [Inject] private TicketService TicketService { get; set; } = default!;
    [Inject] private AuthState AuthState { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private LocalidadDTO[] localidades = [];
    private PartidoDTO? partido;
    private bool isLoading = true;
    private string? errorMessage;

    protected override void OnInitialized()
    {
        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadLocalidades();
    }

    private async Task LoadLocalidades()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var partidos = await TicketService.ObtenerPartidosDisponiblesAsync();
            partido = partidos.FirstOrDefault(p => p.Codigo == CodigoPartido);

            localidades = await TicketService.ObtenerLocalidadesPorPartidoAsync(CodigoPartido);
        }
        catch (Exception)
        {
            errorMessage = "No se pudieron cargar las localidades. Verifique la conexión con el servidor.";
        }
        finally
        {
            isLoading = false;
        }
    }
}
