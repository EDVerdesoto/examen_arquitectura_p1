@page "/partidos"
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Partidos disponibles - TicketPremium</PageTitle>

<div class="card page-header-card mb-4">
    <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
        <div class="d-flex align-items-center gap-3">
            <img src="images/monster-moreira.jpg" class="header-card-img" alt="" />
            <div class="text-center text-md-start">
                <h1 class="fs-2 mb-1">
                    <i class="bi bi-calendar-event"></i> Partidos disponibles
                </h1>
                <p class="mb-0 opacity-75">Encuentra los mejores partidos y compra tus boletos</p>
            </div>
        </div>
        <NavLink href="/resumen" class="btn-header-outline">
            <i class="bi bi-bar-chart-fill"></i> Resumen de ventas
        </NavLink>
    </div>
</div>

@if (!AuthState.IsAuthenticated)
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle-fill"></i>
        Debe <a href="/login" class="alert-link">iniciar sesión</a> para comprar boletos.
    </div>
}

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
        <p class="mt-2 text-muted">Cargando partidos...</p>
    </div>
}
else if (errorMessage != null)
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (partidos.Length == 0)
{
    <div class="alert alert-info">No hay partidos disponibles en este momento.</div>
}
else
{
    <div class="row g-4 justify-content-center">
        @foreach (var partido in partidos)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm match-card">
                    <div class="card-body">
                        <div class="match-teams-row">
                            <div class="match-team-local">
                                <span class="team-name">@partido.EquipoLocal</span>
                            </div>
                            <div class="vs-text">VS</div>
                            <div class="match-team-visita">
                                <span class="team-name">@partido.EquipoVisita</span>
                            </div>
                        </div>
                        <hr class="match-divider" />
                        <div class="row fs-5 mb-3">
                            <div class="col-12 col-sm-6 mb-2 mb-sm-0">
                                <i class="bi bi-calendar3 text-dark"></i>
                                <span class="ms-2">@partido.Fecha.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <div class="col-12 col-sm-6">
                                <i class="bi bi-geo-alt-fill text-dark"></i>
                                <span class="ms-2">@partido.Lugar</span>
                            </div>
                        </div>
                        <a href="/partido/@partido.Codigo/localidades" class="btn-match-action">
                            <i class="bi bi-ticket-perforated"></i> Ver localidades
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    [Inject] private TicketService TicketService { get; set; } = default!;
    [Inject] private AuthState AuthState { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private PartidoDTO[] partidos = [];
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadPartidos();
    }

    private async Task LoadPartidos()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            partidos = await TicketService.ObtenerPartidosDisponiblesAsync();
        }
        catch (Exception)
        {
            errorMessage = "No se pudieron cargar los partidos. Verifique la conexión con el servidor.";
        }
        finally
        {
            isLoading = false;
        }
    }
}
