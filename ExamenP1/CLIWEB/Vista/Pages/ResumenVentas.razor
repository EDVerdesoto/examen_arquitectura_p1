@page "/resumen-ventas/{CodigoPartido:int}"
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Resumen de Ventas - TicketPremium</PageTitle>


<div class="card page-header-card mb-4">
    <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
        <div class="d-flex align-items-center gap-3">
            <img src="images/monster-moreira.jpg" class="header-card-img" alt="" />
            <div class="text-center text-md-start">
                <h1 class="fs-2 mb-1">
                    <i class="bi bi-bar-chart-fill"></i> Resumen de ventas
                </h1>
            @if (resumen != null)
            {
                <p class="mb-0 opacity-75">
                    <i class="bi bi-trophy-fill"></i> @resumen.Partido
                    <span class="mx-1">—</span>
                    <i class="bi bi-calendar3"></i> @resumen.Fecha.ToString("dd/MM/yyyy HH:mm")
                    <span class="mx-1">—</span>
                    <span>#@CodigoPartido</span>
                </p>
            }
            </div>
        </div>
        <div class="d-flex gap-2">
            <a href="/partido/@CodigoPartido/localidades" class="btn-header-outline">
                <i class="bi bi-pin-map"></i> Localidades
            </a>
            <a href="/resumen" class="btn-header-outline">
                <i class="bi bi-bar-chart-fill"></i> Resumen
            </a>
        </div>
    </div>
</div>

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
        <p class="mt-2 text-muted">Cargando resumen...</p>
    </div>
}
else if (errorMessage != null)
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (resumen != null)
{
    @if (resumen.Detalles.Length == 0)
    {
        <div class="alert alert-info">Aún no se han registrado ventas para este partido.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-striped align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Localidad</th>
                        <th class="text-end">Boletos vendidos</th>
                        <th class="text-end">Total recaudado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var detalle in resumen.Detalles)
                    {
                        <tr>
                            <td>
                                <i class="bi bi-geo-alt-fill text-primary"></i> @detalle.Localidad
                            </td>
                            <td class="text-end">
                                <span class="badge bg-primary fs-6">@detalle.Vendidos</span>
                            </td>
                            <td class="text-end fw-bold">$@detalle.TotalRecaudado.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-light">
                    <tr>
                        <td><strong>TOTALES</strong></td>
                        <td class="text-end">
                            <strong>@resumen.Detalles.Sum(d => d.Vendidos)</strong>
                        </td>
                        <td class="text-end">
                            <strong class="text-success fs-5">$@resumen.Detalles.Sum(d => d.TotalRecaudado).ToString("N2")</strong>
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>
    }
}


@code {
    [Parameter] public int CodigoPartido { get; set; }

    [Inject] private TicketService TicketService { get; set; } = default!;
    [Inject] private AuthState AuthState { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private ResumenVentaDTO? resumen;
    private bool isLoading = true;
    private string? errorMessage;

    protected override void OnInitialized()
    {
        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            resumen = await TicketService.ObtenerResumenVentasAsync(CodigoPartido);
        }
        catch (Exception)
        {
            errorMessage = "No se pudo cargar el resumen de ventas. Verifique la conexión.";
        }
        finally
        {
            isLoading = false;
        }
    }
}
