@page "/login"
@layout Layout.EmptyLayout
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Iniciar sesión - TicketPremium</PageTitle>

<div class="container">
    <div class="row justify-content-center align-items-center min-vh-100">
        <div class="col-md-5 col-lg-4 d-none d-md-block pe-md-4">
            <img src="images/ldu-estadio-scaled-e1709730565139.jpeg" class="img-fluid rounded shadow" alt="Estadio" />
        </div>
        <div class="col-md-5 col-lg-4">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h3 class="card-title text-center mb-4">
                    <i class="bi bi-ticket-perforated-fill"></i> TicketPremium
                </h3>
                <h5 class="text-center text-muted mb-4">Iniciar sesión</h5>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger py-2">@errorMessage</div>
                }

                <EditForm Model="loginModel" OnValidSubmit="HandleLogin" FormName="loginForm">
                    <div class="mb-3">
                        <label for="username" class="form-label">Usuario</label>
                        <InputText id="username" class="form-control" @bind-Value="loginModel.Username"
                                   placeholder="Nombre de usuario" disabled="@isLoading" />
                        <ValidationMessage For="@(() => loginModel.Username)" />
                    </div>
                    <div class="mb-3">
                        <label for="password" class="form-label">Clave</label>
                        <InputText id="password" type="password" class="form-control" @bind-Value="loginModel.Password"
                                   placeholder="Contraseña" disabled="@isLoading" />
                        <ValidationMessage For="@(() => loginModel.Password)" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            <span>Ingresando...</span>
                        }
                        else
                        {
                            <span>Ingresar</span>
                        }
                    </button>
                </EditForm>
            </div>
        </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    private LoginModel loginModel { get; set; } = null!;

    [Inject] private TicketService TicketService { get; set; } = default!;
    [Inject] private AuthState AuthState { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private bool isLoading;
    private string? errorMessage;

    protected override void OnInitialized()
    {
        loginModel ??= new();
        if (AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/partidos");
        }
    }

    private async Task HandleLogin()
    {
        errorMessage = null;
        isLoading = true;

        try
        {
            var response = await TicketService.LoginAsync(loginModel.Username, loginModel.Password);

            if (response.Exito)
            {
                AuthState.Login(response.UsuarioId, loginModel.Username);
                Navigation.NavigateTo("/partidos");
            }
            else
            {
                errorMessage = response.Mensaje ?? "Credenciales inválidas.";
            }
        }
        catch (Exception)
        {
            errorMessage = "Error de conexión con el servidor. Verifique que los servicios estén disponibles.";
        }
        finally
        {
            isLoading = false;
        }
    }


}
