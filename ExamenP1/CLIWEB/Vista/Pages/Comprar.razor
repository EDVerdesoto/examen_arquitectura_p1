@page "/comprar/{CodigoPartido:int}/{CodigoLocalidad}"
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Comprar boletos - TicketPremium</PageTitle>

@if (partido != null)
{
    <div class="card page-header-card mb-4">
        <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
            <div class="text-center text-md-start">
                <h1 class="fs-2 mb-1">
                    <i class="bi bi-cart3"></i> Comprar boletos
                </h1>
                <p class="mb-0 opacity-75">
                    <i class="bi bi-trophy-fill"></i> @partido.EquipoLocal vs @partido.EquipoVisita
                    <span class="mx-1">—</span>
                    <i class="bi bi-calendar3"></i> @partido.Fecha.ToString("dd/MM/yyyy HH:mm")
                    <span class="mx-1">—</span>
                    <i class="bi bi-geo-alt-fill"></i> @partido.Lugar
                </p>
            </div>
        </div>
    </div>
}

@if (compraExitosa != null)
{
    <div class="row g-4 align-items-stretch">
        <div class="col-lg-6">
            <div class="card shadow-sm compra-card border-success h-100">
                <div class="card-body p-4 d-flex flex-column">
                    <div class="text-center mb-3">
                        <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
                        <h3 class="mt-3">Compra exitosa</h3>
                        <p class="text-muted">@compraExitosa.Mensaje</p>
                    </div>

                    <div class="mb-3 p-3 bg-light rounded">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Localidad:</span>
                            <strong>@(localidad?.CodigoLocalidad ?? CodigoLocalidad)</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Cantidad:</span>
                            <strong>@compraModel.Cantidad</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Precio unitario:</span>
                            <strong>$@(localidad?.Precio.ToString("N2") ?? "0.00")</strong>
                        </div>
                    </div>

                    <hr class="mb-3" />

                    <div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Factura #:</span>
                            <strong>@compraExitosa.FacturaId</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Subtotal:</span>
                            <strong>$@compraExitosa.Subtotal.ToString("N2")</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>IVA (15%):</span>
                            <strong>$@compraExitosa.Iva.ToString("N2")</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-2 border-top pt-2">
                            <span>Total:</span>
                            <strong class="text-success fs-5">$@compraExitosa.Total.ToString("N2")</strong>
                        </div>
                    </div>

                    <div class="mt-auto pt-3">
                        <a href="/partidos" class="btn btn-primary me-2">
                            <i class="bi bi-calendar-event"></i> Ver más partidos
                        </a>
                        <button class="btn btn-outline-primary" @onclick="NuevaCompra">
                            <i class="bi bi-cart-plus"></i> Nueva compra
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="compra-image-placeholder">
                <img src="images/ldu-estadio-scaled-e1709730565139.jpeg" alt="Estadio" class="img-fluid rounded" />
            </div>
        </div>
    </div>
}
else
{
    <div class="row g-4 align-items-stretch">
        <div class="col-lg-7">
            <div class="card shadow-sm compra-card h-100">
                <div class="card-body p-4">
                    <a href="/partido/@CodigoPartido/localidades" class="btn btn-link btn-sm px-0 mb-3">
                        <i class="bi bi-arrow-left"></i> Volver a localidades
                    </a>

                    @if (isLoadingLocalidad)
                    {
                        <div class="text-center py-3">
                            <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                            <span class="ms-2 text-muted">Cargando información...</span>
                        </div>
                    }
                    else if (errorMessage != null)
                    {
                        <div class="alert alert-danger">@errorMessage</div>
                    }
                    else if (localidad != null)
                    {
                        <div class="mb-4 p-3 bg-light rounded">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Localidad:</span>
                                <strong>@localidad.CodigoLocalidad</strong>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Precio unitario:</span>
                                <strong>$@localidad.Precio.ToString("N2")</strong>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="text-muted">Disponibles:</span>
                                <strong>@localidad.Disponibilidad</strong>
                            </div>
                        </div>

                        <EditForm Model="compraModel" OnValidSubmit="HandleComprar" FormName="compraForm">
                            <div class="mb-4">
                                <label for="cantidad" class="form-label">Cantidad de boletos</label>
                                <InputNumber id="cantidad" class="form-control" @bind-Value="compraModel.Cantidad"
                                             min="1" max="@localidad.Disponibilidad" step="1" />
                                <div class="form-text">Máximo @localidad.Disponibilidad boleto(s) disponible(s).</div>
                                <ValidationMessage For="@(() => compraModel.Cantidad)" />
                            </div>

                            @if (compraModel.Cantidad > 0)
                            {
                                <div class="precio-desglose mb-4">
                                    <div class="d-flex justify-content-between mb-1">
                                        <span class="text-muted">Subtotal</span>
                                        <span>$@((compraModel.Cantidad * localidad.Precio).ToString("N2"))</span>
                                    </div>
                                    <div class="d-flex justify-content-between mb-1">
                                        <span class="text-muted">IVA (15%)</span>
                                        <span>$@((compraModel.Cantidad * localidad.Precio * 0.15m).ToString("N2"))</span>
                                    </div>
                                    <div class="d-flex justify-content-between total-line">
                                        <span>Total</span>
                                        <strong class="text-success">$@((compraModel.Cantidad * localidad.Precio * 1.15m).ToString("N2"))</strong>
                                    </div>
                                </div>
                            }

                            <button type="submit" class="btn btn-primary w-100" disabled="@isComprando">
                                @if (isComprando)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                    <span>Procesando...</span>
                                }
                                else
                                {
                                    <i class="bi bi-check-lg"></i>
                                    <span>Confirmar compra</span>
                                }
                            </button>
                        </EditForm>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="compra-image-placeholder">
                <img src="images/ldu-estadio-scaled-e1709730565139.jpeg" alt="Estadio" class="img-fluid rounded" />
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int CodigoPartido { get; set; }
    [Parameter] public string CodigoLocalidad { get; set; } = string.Empty;

    [SupplyParameterFromForm]
    private CompraModel compraModel { get; set; } = null!;

    [Inject] private TicketService TicketService { get; set; } = default!;
    [Inject] private AuthState AuthState { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private LocalidadDTO? localidad;
    private PartidoDTO? partido;
    private CompraResponse? compraExitosa;
    private bool isLoadingLocalidad = true;
    private bool isComprando;
    private string? errorMessage;

    protected override void OnInitialized()
    {
        compraModel ??= new();
        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        CodigoLocalidad = Uri.UnescapeDataString(CodigoLocalidad);

        if (compraExitosa != null)
            return;

        await LoadLocalidad();
    }

    private async Task LoadLocalidad()
    {
        isLoadingLocalidad = true;
        errorMessage = null;

        try
        {
            var partidos = await TicketService.ObtenerPartidosDisponiblesAsync();
            partido = partidos.FirstOrDefault(p => p.Codigo == CodigoPartido);

            var localidades = await TicketService.ObtenerLocalidadesPorPartidoAsync(CodigoPartido);
            localidad = localidades.FirstOrDefault(l => l.CodigoLocalidad == CodigoLocalidad);

            if (localidad == null)
            {
                errorMessage = "Localidad no encontrada.";
            }
            else if (localidad.Disponibilidad == 0)
            {
                errorMessage = "Esta localidad ya no tiene boletos disponibles.";
            }
        }
        catch (Exception)
        {
            errorMessage = "Error al cargar la información de la localidad.";
        }
        finally
        {
            isLoadingLocalidad = false;
        }
    }

    private async Task HandleComprar()
    {
        errorMessage = null;
        isComprando = true;

        try
        {
            var request = new CompraRequest
            {
                UsuarioId = AuthState.UsuarioId,
                CodigoPartido = CodigoPartido,
                CodigoLocalidad = localidad!.CodigoLocalidad,
                Cantidad = compraModel.Cantidad,
                PrecioUnitario = localidad!.Precio,
                PartidoDescripcion = $"Partido #{CodigoPartido} - {CodigoLocalidad}",
                FechaPartido = DateTime.Now
            };

            var response = await TicketService.ComprarBoletosAsync(request);

            if (response.Exito)
            {
                compraExitosa = response;
            }
            else
            {
                errorMessage = response.Mensaje ?? "La compra no pudo ser procesada.";
            }
        }
        catch (Exception)
        {
            errorMessage = "Error al procesar la compra. Verifique la conexión.";
        }
        finally
        {
            isComprando = false;
        }
    }

    private async Task NuevaCompra()
    {
        compraExitosa = null;
        compraModel = new CompraModel();
        await LoadLocalidad();
    }


}
