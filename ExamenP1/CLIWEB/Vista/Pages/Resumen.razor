@page "/resumen"
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Resumen de Ventas - TicketPremium</PageTitle>

<div class="card page-header-card mb-4">
    <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
        <div class="d-flex align-items-center gap-3">
            <img src="images/monster-plata.png" class="header-card-img" alt="" />
            <div class="text-center text-md-start">
                <h1 class="fs-2 mb-1">
                    <i class="bi bi-bar-chart-fill"></i> Resumen de ventas por partido
                </h1>
                <p class="mb-0 opacity-75">Consulta el desempeño de ventas de cada encuentro</p>
            </div>
        </div>
        <a href="/partidos" class="btn-header-outline">
            <i class="bi bi-arrow-left"></i> Volver a partidos
        </a>
    </div>
</div>

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
        <p class="mt-2 text-muted">Cargando información...</p>
    </div>
}
else if (errorMessage != null)
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (resumenes.Count == 0)
{
    <div class="alert alert-info">No hay información de ventas disponible.</div>
}
else
{
    <div class="row g-4">
        @foreach (var (partido, resumen) in resumenes)
        {
            var totalVendidos = resumen.Detalles.Sum(d => d.Vendidos);
            var totalRecaudado = resumen.Detalles.Sum(d => d.TotalRecaudado);

            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm match-card">
                    <div class="card-body">
                        <div class="match-teams-row">
                            <div class="match-team-local">
                                <span class="team-name">@partido.EquipoLocal</span>
                            </div>
                            <div class="vs-text">VS</div>
                            <div class="match-team-visita">
                                <span class="team-name">@partido.EquipoVisita</span>
                            </div>
                        </div>
                        <hr class="match-divider" />
                        <div class="row fs-5 mb-3">
                            <div class="col-12 col-sm-6 mb-2 mb-sm-0">
                                <i class="bi bi-calendar3 text-dark"></i>
                                <span class="ms-2">@partido.Fecha.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <div class="col-12 col-sm-6">
                                <i class="bi bi-geo-alt-fill text-dark"></i>
                                <span class="ms-2">@partido.Lugar</span>
                            </div>
                        </div>
                        <div class="d-flex justify-content-around text-center mb-3">
                            <div>
                                <div class="fs-4 fw-bold text-primary">@totalVendidos</div>
                                <small class="text-muted">Vendidos</small>
                            </div>
                            <div>
                                <div class="fs-4 fw-bold text-success">$@totalRecaudado.ToString("N0")</div>
                                <small class="text-muted">Recaudado</small>
                            </div>
                        </div>
                        <a href="/resumen-ventas/@partido.Codigo" class="btn-match-action">
                            <i class="bi bi-eye"></i> Ver detalle
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    [Inject] private TicketService TicketService { get; set; } = default!;
    [Inject] private AuthState AuthState { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private List<(PartidoDTO Partido, ResumenVentaDTO Resumen)> resumenes = new();
    private bool isLoading = true;
    private string? errorMessage;

    protected override void OnInitialized()
    {
        if (!AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var partidos = await TicketService.ObtenerPartidosDisponiblesAsync();
            resumenes.Clear();

            foreach (var partido in partidos)
            {
                try
                {
                    var resumen = await TicketService.ObtenerResumenVentasAsync(partido.Codigo);
                    resumenes.Add((partido, resumen));
                }
                catch
                {
                    // Skip matches that fail to load summary
                }
            }

            resumenes = resumenes.OrderByDescending(r => r.Partido.Fecha).ToList();
        }
        catch (Exception)
        {
            errorMessage = "No se pudo cargar la información de ventas. Verifique la conexión.";
        }
        finally
        {
            isLoading = false;
        }
    }
}
